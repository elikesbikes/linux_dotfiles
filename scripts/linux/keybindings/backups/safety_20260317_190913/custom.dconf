[custom0]
binding='<Control><Alt>a'
command='code'
name='Open VS Code'

[custom1]
binding='<Control><Alt>e'
command='thunderbird'
name='Open Thunderbird'

[custom10]
binding='<Control><Alt>v'
command='/home/ecloaiza/nerd-dictation/nerd-dictation begin --vosk-model-dir /home/ecloaiza/nerd-dictation/model'
name='Nerd Dictation Start'

[custom11]
binding='<Control><Alt><Shift>v'
command='/home/ecloaiza/nerd-dictation/nerd-dictation end'
name='Nerd Dictation Stop'

[custom2]
binding='<Shift><Alt>2'
command='alacritty'
name='New Alacritty Window'

[custom3]
binding='<Control><Alt>k'
command='kitty'
name='KItty'

[custom4]
binding='<Control>F1'
command="sh -c 'asdcontrol $(asdcontrol --detect /dev/usb/hiddev* 2>/dev/null | grep ^/dev/usb/hiddev | cut -d: -f1) -- -5000'"
name='Apple Brightness Down (ASDControl)'

[custom5]
binding='<Control>F2'
command="sh -c 'asdcontrol $(asdcontrol --detect /dev/usb/hiddev* 2>/dev/null | grep ^/dev/usb/hiddev | cut -d: -f1) -- +5000'"
name='Apple Brightness Up (ASDControl)'

[custom6]
binding='<Control><Shift>F2'
command="sh -c 'asdcontrol $(asdcontrol --detect /dev/usb/hiddev* 2>/dev/null | grep ^/dev/usb/hiddev | cut -d: -f1) -- +60000'"
name='Apple Brightness Max (ASDControl)'

[custom7]
binding='<Control><Alt>m'
command='spotify'
name='Spotify'

[custom8]
binding='<Control><Alt>o'
command='flatpak run md.obsidian.Obsidian'
name='Obsidian'

[custom9]
binding='<Control><Alt>d'
command='/home/ecloaiza/.local/bin/claude-dictate'
name='Claude Dictation'

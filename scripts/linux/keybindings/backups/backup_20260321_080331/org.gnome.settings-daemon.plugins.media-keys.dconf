[/]
calculator=['<Control><Alt>c']
control-center=['<Control><Alt>s']
custom-keybindings=['/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom0/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom1/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom2/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom3/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom4/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom5/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom6/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom7/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom8/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom9/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom10/', '/org/gnome/settings-daemon/plugins/media-keys/custom-keybindings/custom11/']
home=['<Control><Alt>h']
next=['<Shift>AudioPlay']
www=['<Control><Alt>b']

[custom-keybindings/custom0]
binding='<Super>space'
command=' ulauncher'
name='Ulauncher'

[custom-keybindings/custom1]
binding='<Control>Print'
command='sh -c -- "flameshot gui"'
name='Flameshot'

[custom-keybindings/custom10]
binding='<Control><Alt>a'
command='code'
name='VS Code'

[custom-keybindings/custom11]
binding='<Control><Alt>s'
command='/home/ecloaiza/.local/bin/stt-toggle.sh'
name='Speech to Text'

[custom-keybindings/custom2]
binding='<Shift><Alt>2'
command='alacritty'
name='New Alacritty Window'

[custom-keybindings/custom3]
binding='<Control><Alt>k'
command='kitty'
name='KItty'

[custom-keybindings/custom4]
binding=" grep ^/dev/usb/hiddev | cut -d: -f1) -- -5000'\"|'<Control>F1'"
name='Apple Brightness Down (ASDControl)'

[custom-keybindings/custom5]
binding=" grep ^/dev/usb/hiddev | cut -d: -f1) -- +5000'\"|'<Control>F2'"
name='Apple Brightness Up (ASDControl)'

[custom-keybindings/custom6]
binding=" grep ^/dev/usb/hiddev | cut -d: -f1) -- +60000'\"|'<Control><Shift>F2'"
name='Apple Brightness Max (ASDControl)'

[custom-keybindings/custom7]
binding='<Control><Alt>m'
command='spotify'
name='Spotify'

[custom-keybindings/custom8]
binding='<Control><Alt>o'
command='flatpak run md.obsidian.Obsidian'
name='Obsidian'

[custom-keybindings/custom9]
binding='<Control><Alt>e'
command='thunderbird'
name='Thunderbird'

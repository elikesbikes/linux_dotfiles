# Global sudo defaults
#
# Keep this file sudo-rs compatible: only directives that BOTH traditional
# sudo and sudo-rs understand belong here. I/O logging (log_output / iolog_dir)
# is NOT supported by sudo-rs and lives in 00-defaults-logging, which
# sync-sudoers.sh excludes when sudo-rs is detected.
Defaults env_keep += "TERMINFO"
